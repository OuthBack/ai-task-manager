# Environment Configuration - Development
# IMPORTANT: Copy this file to .env and fill in your actual values.
# All developers on the team must have their own .env file with their Gemini API key.
# .env is in .gitignore and should NEVER be committed to source control.

# Application Port
PORT=3001

# Database Configuration
DATABASE_PATH=./data/tasks.db

# Gemini AI API Configuration
# REQUIRED: Get your API key from https://ai.google.dev/
# 1. Visit https://ai.google.dev/
# 2. Click "Get API key" in Google AI Studio
# 3. Create or select a project
# 4. Copy the API key and paste it below
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/models
GEMINI_MODEL=gemini-1.5-flash

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Environment
NODE_ENV=development
